---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/global.css';

const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;

const projects = [
  {
    num: '001',
    name: 'NUCLEUS.IO',
    desc: 'Flyable 3D universe built with Three.js. Pilot a spaceship through neon physics, collect project orbs, and squash space bugs — custom GLSL shaders, procedural audio, and multi-layer post-processing.',
    tags: ['Three.js', 'WebGL', 'GLSL', 'Vite', 'Audio'],
    link: 'https://nucleus-io.vercel.app',
  },
  {
    num: '002',
    name: 'Chewsy',
    desc: 'Real-time multiplayer restaurant swiping. Engineered robust Firebase state-synchronization to resolve concurrent match collisions across mobile clients with zero latency.',
    tags: ['React', 'Firebase', 'Framer Motion'],
    link: 'https://chewsy-51ce4.web.app/',
  },
  {
    num: '003',
    name: 'T-Minus',
    desc: 'Cosmic countdown platform featuring a procedural starfield renderer via Canvas API. Optimized draw loops to maintain 60 FPS while rendering hundreds of alpha-blended stars with zero external dependencies.',
    tags: ['Vanilla JS', 'Canvas API', 'UI Design'],
    link: 'https://roywg925.github.io/T-MINUS/',
  },
  {
    num: '004',
    name: 'Market Sentiment X TAIEX',
    desc: 'Architected an end-to-end NLP data pipeline processing 20,000+ posts, transforming volatile text into a predictive market indicator. Increased predictive accuracy (F1 score: 0.23 → 0.68).',
    tags: ['PyTorch', 'BERT', 'Data Engineering'],
    link: 'https://github.com/RoyWG925/ptt-sentiment-stock-analysis',
  },
  {
    num: '005',
    name: 'GigaJoule: Scrap Matrix',
    desc: 'Physics-based roguelite architected in Godot Engine. Designed complex systems for multi-cell item synergy evaluation and dynamic grid adjacency logic to drive settlement meta-progression.',
    tags: ['Godot', 'GDScript', 'System Design'],
    link: null,
  },
];
---
<BaseLayout>
  <!-- NAV BANNER -->
  <header class="nav-banner">
    <div class="nav-logo-area">R/W</div>
    <div class="nav-links">
      <a href="#work" class="nav-link">PROJECTS</a>
      <a href="#about" class="nav-link">ABOUT</a>
      
      <a href="https://github.com/RoyWG925" target="_blank" rel="noopener" aria-label="GitHub" class="nav-link icon-link">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
      </a>
      <a href="https://www.linkedin.com/in/roy-wang-258b082b9/" target="_blank" rel="noopener" aria-label="LinkedIn" class="nav-link icon-link">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
      </a>
      
      <a href={`${base}/Roy_Wang_Resume.pdf`} target="_blank" rel="noopener" class="nav-link nav-accent">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 0.5rem;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
        RESUME
      </a>
      <a href="mailto:jg971402@gmail.com" class="nav-link nav-cta">EMAIL ME</a>
    </div>
  </header>

  <div class="nav-controls">
    <button id="btn-stress-test" class="system-btn btn-alert" title="WARNING: CAUSES SYSTEM OVERLOAD">[ SYS_STRESS_TEST ]</button>
    <button id="btn-xray-toggle" class="system-btn" title="TOGGLE BLUEPRINT VIEW">[ X-RAY : OFF ]</button>
  </div>

  <!-- HERO -->
  <main class="hero" style="position: relative;">
    <!-- Physics canvas now covers the whole hero area to align coordinates -->
    <canvas id="physics-canvas" style="position: absolute; top:0; left:0; width: 100%; height: 100%; pointer-events: auto; z-index: 5; opacity: 0.8;" aria-hidden="true"></canvas>

    <div class="hero-info-strip" style="position: relative; z-index: 10;">
      <div class="info-cell">
        <span class="info-label">Status</span>
        <span class="info-value">Open to Work / 2026</span>
      </div>
      <div class="info-cell">
        <span class="info-label">Location</span>
        <span class="info-value">Taipei, Taiwan</span>
      </div>
      <div class="info-cell">
        <span class="info-label">Focus [01]</span>
        <span class="info-value">AI Application Engineering</span>
      </div>
      <div class="info-cell">
        <span class="info-label">Focus [02]</span>
        <span class="info-value">Creative Technology / HCI</span>
      </div>
    </div>

    <div class="hero-main" style="position: relative; z-index: 10; pointer-events: none;">
      <div class="hero-text-col" style="flex: 1; pointer-events: auto;">
        <div class="hero-name-wrap">
          <h1 class="hero-name">Roy Wang</h1>
        </div>
        <div class="hero-role-wrap">
          <div class="hero-role">AI Application Engineer</div>
          <div class="hero-role" style="color: var(--border);">+</div>
          <div class="hero-role" style="color: var(--accent-2);">Creative Technologist</div>
        </div>

        <p class="hero-desc" style="margin-top: 3rem;">
          I build AI-powered products end-to-end — from fine-tuning models 
          and designing RAG pipelines to shipping polished, interactive interfaces.
        </p>
      </div>

      <div class="hero-photo-col" style="pointer-events: auto;">
        <div class="hero-photo-wrapper">
          <img src={`${base}/profile.jpg`} alt="Roy Wang" class="hero-photo" />
          <div class="photo-overlay"></div>
          <div class="hero-photo-tag">ID: R_WANG // ENGINEER</div>
        </div>
      </div>
    </div>
  </main>

  <!-- GIANT TICKER -->
  <div class="ticker-section" aria-hidden="true">
    <div class="ticker-track">
      <span>RAG PIPELINES</span> //
      <span>LANGCHAIN</span> //
      <span>THREE.JS</span> //
      <span>BERT FINE-TUNING</span> //
      <span>GEMINI API</span> //
      <span>REACT</span> //
      <span>SYSTEM DESIGN</span> //
      <span>RAG PIPELINES</span> //
      <span>LANGCHAIN</span> //
      <span>THREE.JS</span> //
      <span>BERT FINE-TUNING</span> //
      <span>GEMINI API</span> //
      <span>REACT</span> //
      <span>SYSTEM DESIGN</span> //
    </div>
  </div>

  <!-- WORK INDEX -->
  <section id="work" class="section-wrapper">
    <div class="section-header-box">
      <div class="sect-title-wrap">
        <span class="sect-index">[ 01 ]</span>
        <h2 class="sect-title">Projects</h2>
      </div>
      <a href="https://github.com/RoyWG925" target="_blank" rel="noopener" class="btn-industrial btn-outline" style="border: 1px solid var(--border); padding: 0.5rem 1rem;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" style="margin-right: 8px;"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
        GitHub Profile
      </a>
    </div>

    <div class="data-table">
      {projects.map((p) => (
        <a href={p.link || '#'} target={p.link ? "_blank" : "_self"} rel="noopener" class="data-row" data-img={p.img ?? undefined} style={!p.link ? "pointer-events: none;" : ""}>
          <div class="data-cell cell-num">[{p.num}]</div>
          <div class="data-cell cell-title">
            <h3 class="proj-title">{p.name}</h3>
            <div class="proj-tech">
              {p.tags.map(t => <span class="tech-tag">{t}</span>)}
            </div>
          </div>
          <div class="data-cell cell-desc">
            {p.desc}
          </div>
          <div class="data-cell cell-action">
            {p.link ? <span>Open Link ↗</span> : <span style="opacity: 0.3;">In Progress</span>}
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- ABOUT -->
  <section id="about" class="section-wrapper" style="padding-bottom: 0; border-bottom: none;">
    <div class="section-header-box" style="margin-bottom: 0; border-bottom: none;">
      <div class="sect-title-wrap">
        <span class="sect-index">[ 02 ]</span>
        <h2 class="sect-title">About Me</h2>
      </div>
    </div>

    <div class="about-grid">
      <!-- 1. Text Context -->
      <div class="about-panel context-panel">
        <div class="about-text">
          <p>
            B.S. Learning Sciences @ <strong>National Taiwan Normal University</strong>. 
            My HCI background gives me a rare lens: modeling how humans interact with complex systems — then building interfaces that collapse that complexity.
          </p>
          <p>
            I work the full vertical — from fine-tuning BERT on 20K+ posts to shipping WebGL experiences with custom GLSL shaders. Currently focused on <strong>AI application architecture</strong>, with production experience across Gemini, LangChain/LangGraph agents, and RAG pipelines.
          </p>
          <p>
            My edge: I don't silo. I build full-stack AI systems — from the embedding layer to the UI — and I ship them fast with agent-assisted workflows (Claude, Cursor, Copilot).
          </p>
        </div>
      </div>
      
      <!-- 2. Manifest List -->
      <div class="about-panel" style="background: var(--bg); padding-top: 1rem;">
        <ul class="manifest-list">
          <li class="manifest-item">
            <span class="manifest-label">AI / LLM</span>
            <span class="manifest-val">LLM API Integration, RAG Pipelines (learning), Prompt Engineering, HuggingFace Embeddings</span>
          </li>
          <li class="manifest-item">
            <span class="manifest-label">Machine Learning</span>
            <span class="manifest-val">Python, PyTorch, HuggingFace Transformers, BERT Fine-tuning, Pandas, Jupyter</span>
          </li>
          <li class="manifest-item">
            <span class="manifest-label">Frontend</span>
            <span class="manifest-val">React, Astro, Three.js / WebGL, GLSL Shaders, Framer Motion, CSS Animation</span>
          </li>
          <li class="manifest-item">
            <span class="manifest-label">Backend / Infra</span>
            <span class="manifest-val">Node.js, Firebase, Supabase, Vercel</span>
          </li>
          <li class="manifest-item">
            <span class="manifest-label">Toolchain</span>
            <span class="manifest-val">Git/GitHub, Cursor, Claude Code, GitHub Copilot, Godot, Figma, Docker</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- POSTER CTA -->
  <section class="contact-poster">
    <h2><span>Let's</span><br/>Talk.</h2>
    <div style="display: flex; gap: 1rem; justify-content: center; align-items: center; margin-top: 2rem;">
      <a href="mailto:jg971402@gmail.com" class="btn-industrial" style="background: var(--bg); color: var(--border); border-color: var(--bg);">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 8px;"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
        Email Me
      </a>
      <a href="https://www.linkedin.com/in/roy-wang-258b082b9/" target="_blank" rel="noopener" class="btn-industrial" style="background: transparent; border-color: var(--bg); color: var(--bg);">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right: 8px;"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
        LinkedIn
      </a>
    </div>
  </section>

  <!-- FOOTER -->
  <footer style="display: flex; justify-content: space-between; padding: 1.5rem 2rem; background: var(--border); color: var(--bg); font-family: var(--font-mono); font-size: 0.75rem; text-transform: uppercase;">
    <span>© 2026 Roy Wang</span>
    <span>Built with Astro // Matter.js</span>
  </footer>

  <script>
    import Matter from 'matter-js';

    // ── SCRAP MATRIX PHYSICS (IDEA C) ──
    const canvas = document.getElementById('physics-canvas') as HTMLCanvasElement;
    if (canvas) {
      const ctx = canvas.getContext('2d')!;
      
      // Setup Engine
      const engine = Matter.Engine.create({ gravity: { x: 0, y: 0.5, scale: 0.001 } });
      const world = engine.world;
      
      let width = window.innerWidth;
      let height = canvas.parentElement ? canvas.parentElement.clientHeight : window.innerHeight;
      canvas.width = width;
      canvas.height = height;

      // Boundaries (Bottom, Left, Right, Top)
      const wallOpts = { isStatic: true, render: { visible: false } };
      let ground = Matter.Bodies.rectangle(width/2, height + 50, width * 2, 100, wallOpts);
      let leftWall = Matter.Bodies.rectangle(-50, height/2, 100, height * 2, wallOpts);
      let rightWall = Matter.Bodies.rectangle(width + 50, height/2, 100, height * 2, wallOpts);
      let ceiling = Matter.Bodies.rectangle(width/2, -100, width * 2, 100, wallOpts);
      Matter.Composite.add(world, [ground, leftWall, rightWall, ceiling]);

      // Add Mouse Constraint so we can DRAG and THROW
      const mouse = Matter.Mouse.create(canvas);
      const mouseConstraint = Matter.MouseConstraint.create(engine, {
        mouse: mouse,
        constraint: {
          stiffness: 0.2,
          render: { visible: false }
        }
      });
      Matter.Composite.add(world, mouseConstraint);

      // Keep the mouse in sync for smooth scrolling/offset if needed
      mouseConstraint.mouse.element.removeEventListener("mousewheel", mouseConstraint.mouse.mousewheel);
      mouseConstraint.mouse.element.removeEventListener("DOMMouseScroll", mouseConstraint.mouse.mousewheel);

      // Data Scraps
      const scraps: Array<{body: Matter.Body, label: string, color: string}> = [];
      const labels = ['SYS_ERR', '[DATA_NODE]', 'FRAG:0x1A', 'NULL', 'REDACTED', 'HCI:INIT', 'NUCLEUS', 'BUFFER'];

      function spawnScrap() {
        if(scraps.length > 20) return; // limit
        const bodyWidth = 100 + Math.random() * 60;
        const bodyHeight = 40;
        const b = Matter.Bodies.rectangle(
          Math.random() * width, 
          -50, 
          bodyWidth, 
          bodyHeight, 
          { 
            restitution: 0.6,
            friction: 0.1,
            frictionAir: 0.01,
            density: 0.005,
            angle: (Math.random() - 0.5) * 0.5
          }
        );
        Matter.Composite.add(world, b);
        
        scraps.push({
          body: b,
          label: labels[Math.floor(Math.random() * labels.length)],
          color: Math.random() > 0.8 ? '#D9381E' : '#111111'
        });
      }

      // X-Ray Toggle Mode
      const btnXray = document.getElementById('btn-xray-toggle');
      if (btnXray) {
        btnXray.addEventListener('click', () => {
          const isActive = document.body.classList.toggle('xray-mode');
          btnXray.classList.toggle('active');
          btnXray.innerText = isActive ? '[ X-RAY : ON ]' : '[ X-RAY : OFF ]';
        });
      }

      // Red Button Stress Test Logic
      const btnStress = document.getElementById('btn-stress-test');
      if(btnStress) {
        btnStress.addEventListener('click', () => {
          // Trigger visual glitch & HUD
          document.body.classList.add('stress-active');
          
          // Reverse Gravity
          engine.gravity.y = -1.2; 
          
          // Explode! Scatter current fragments
          scraps.forEach(s => {
             Matter.Body.setVelocity(s.body, {
                 x: (Math.random() - 0.5) * 40,
                 y: (Math.random() - 0.5) * 40
             });
          });

          // Inject 30 massive system error fragments
          for(let i=0; i<30; i++) {
              setTimeout(() => {
                const b = Matter.Bodies.rectangle(Math.random() * width, height - 20, 100 + Math.random() * 60, 40, { 
                  restitution: 0.8, friction: 0.1, density: 0.005, angle: (Math.random() - 0.5)
                });
                Matter.Composite.add(world, b);
                scraps.push({ body: b, label: 'FATAL_ERR', color: '#D9381E' });
              }, i * 20);
          }

          // Restore normal state after 3 seconds
          setTimeout(() => {
              engine.gravity.y = 0.5;
              document.body.classList.remove('stress-active');
              btnStress.innerText = '[ REBOOTING... ]';
              setTimeout(() => btnStress.innerText = '[ SYS_STRESS_TEST ]', 2000);
          }, 3500);
        });
      }

      // Drop scraps on interval
      // Keep number limited
      const spawnInterval = setInterval(() => {
        if(scraps.length < 15) spawnScrap();
      }, 2500);
      for(let i=0; i<8; i++) setTimeout(spawnScrap, i*300);

      // Custom Render Loop
      function render() {
        ctx.clearRect(0, 0, width, height);

        // Draw Scraps
        for (let s of scraps) {
          const { body, label, color } = s;
          const pos = body.position;
          
          ctx.save();
          ctx.translate(pos.x, pos.y);
          ctx.rotate(body.angle);
          
          // Draw rect
          const rectW = 140; 
          const rectH = 40;
          ctx.lineWidth = 2;
          
          // Check if being dragged
          const isDragged = mouseConstraint.body === body;
          
          if(isDragged) {
            ctx.shadowColor = color;
            ctx.shadowBlur = 15;
            ctx.strokeStyle = '#fff';
            ctx.fillStyle = color;
          } else {
            ctx.strokeStyle = color;
            ctx.fillStyle = color === '#D9381E' ? 'rgba(217, 56, 30, 0.1)' : 'transparent';
          }
          
          ctx.strokeRect(-rectW/2, -rectH/2, rectW, rectH);
          ctx.fillRect(-rectW/2, -rectH/2, rectW, rectH);

          // Draw text
          ctx.fillStyle = isDragged ? (color === '#111111' ? '#fff' : '#fff') : color;
          ctx.font = '600 14px "IBM Plex Mono", monospace';
          ctx.textAlign = 'center';
          ctx.textBaseline = 'middle';
          ctx.fillText(label, 0, 0);

          ctx.restore();
        }

        Matter.Engine.update(engine, 1000/60);
        requestAnimationFrame(render);
      }

      render();

      window.addEventListener('resize', () => {
        width = window.innerWidth;
        height = canvas.parentElement ? canvas.parentElement.clientHeight : window.innerHeight;
        canvas.width = width;
        canvas.height = height;
        Matter.Body.setPosition(ground, { x: width/2, y: height + 50 });
        Matter.Body.setPosition(rightWall, { x: width + 50, y: height/2 });
      });
    }
  </script>
</BaseLayout>
